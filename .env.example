# Environment Variables — copy this file to .env for local development
# Never commit .env to Git!

# Django Secret Key (generate a new one for production)
SECRET_KEY=your-very-secret-key-here

# Set to True only for local development, False for production
DEBUG=False

# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Railway automatically sets this when deployed
# RAILWAY_ENVIRONMENT=production
